# ─────────────────────────────────────────────────────────────────────────────
# Gecko Pulse — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it contains your private key!
# ─────────────────────────────────────────────────────────────────────────────

# Google Service Account credentials
# Found in your service account JSON key file.
GOOGLE_CLIENT_EMAIL=gecko-pulse@your-project.iam.gserviceaccount.com

# The private key — copy the FULL value from your JSON key file,
# including the -----BEGIN PRIVATE KEY----- and -----END PRIVATE KEY----- lines.
# Paste it inside double quotes. The \n characters are fine — don't replace them.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvA...your key here...\n-----END PRIVATE KEY-----\n"
