{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "env": {
    "SLACK_BOT_TOKEN": "@slack_bot_token",
    "SLACK_SIGNING_SECRET": "@slack_signing_secret",
    "GOOGLE_SHEET_ID": "@google_sheet_id",
    "GOOGLE_CREDENTIALS": "@google_credentials",
    "PULSE_CHANNEL": "@pulse_channel",
    "ADMIN_USER_IDS": "@admin_user_ids"
  }
}
